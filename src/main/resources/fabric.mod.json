{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "Mighty mod but for Cobalt!",
  "authors": [
    "Bloxfriend590"
  ],
  "contact": {
    "sources": "https://github.com/EvilPiza/MightyCobaltAddon"
  },
  "license": "CC0-1.0",
  "icon": "assets/${mod_id}/icon.png",
  "environment": "*",
  "entrypoints": {
    "cobalt": [
      {
        "adapter": "kotlin",
        "value": "${base_group}.${mod_name}"
      }
    ]
  },
  "mixins": [
    "${mod_id}.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "~${minecraft_version}",
    "java": ">=25",
    "fabric-language-kotlin": ">=${fabric_kotlin_version}"
  }
}
